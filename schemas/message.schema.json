{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-taal/schemas/message.schema.json",
  "title": "ECP message",
  "description": "Volledig gelogd discreet bericht tussen twee agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "run_id",
    "episode_id",
    "sender_id",
    "receiver_id",
    "symbols",
    "channel_bits"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^ecp[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "sender_id": {
      "type": "string",
      "minLength": 1
    },
    "receiver_id": {
      "type": "string",
      "minLength": 1
    },
    "symbols": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 15
      }
    },
    "channel_bits": {
      "type": "integer",
      "minimum": 1
    }
  }
}
